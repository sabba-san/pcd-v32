# --- Flask Settings ---
FLASK_APP=app:app
FLASK_ENV=development
SECRET_KEY=change-me-in-local-env

# --- Database Connection (For Docker) ---
DATABASE_URL=postgresql://user:password@flask_db:5432/flaskdb

# --- AI API Keys ---
GROQ_API_KEY=replace-with-your-local-groq-api-key
GROQ_API_KEY_REPORT=replace-with-your-report-api-key
GROQ_API_KEY_CHATBOT=replace-with-your-chatbot-api-key
